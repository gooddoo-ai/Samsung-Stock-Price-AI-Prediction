<!-- Gauge -->
<div class="card">
  <div class="section-header" style="margin-bottom:4px;">
    <div class="section-title">종합 투자 신호</div>
    <div class="section-line"></div>
  </div>
  <div class="gauge-wrap">
    <svg class="gauge-svg" width="220" height="130" viewBox="0 0 220 130">
      <!-- Background arc -->
      <path d="M 20 110 A 90 90 0 0 1 200 110" fill="none" stroke="#1a3554" stroke-width="18" stroke-linecap="round"/>
      <!-- Danger zone (sell) -->
      <path d="M 20 110 A 90 90 0 0 1 65 35" fill="none" stroke="rgba(255,71,87,0.4)" stroke-width="18" stroke-linecap="round"/>
      <!-- Neutral zone -->
      <path d="M 65 35 A 90 90 0 0 1 155 35" fill="none" stroke="rgba(255,204,0,0.4)" stroke-width="18" stroke-linecap="round"/>
      <!-- Buy zone -->
      <path d="M 155 35 A 90 90 0 0 1 200 110" fill="none" stroke="rgba(0,255,157,0.4)" stroke-width="18" stroke-linecap="round"/>

      <!-- Active fill — pointing toward BUY (Strong Buy ~78%) -->
      <path d="M 20 110 A 90 90 0 1 1 185 75" fill="none" stroke="url(#ggrad)" stroke-width="18" stroke-linecap="round" stroke-dasharray="220 283" />

      <defs>
        <linearGradient id="ggrad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#ff4757"/>
          <stop offset="50%" style="stop-color:#ffcc00"/>
          <stop offset="100%" style="stop-color:#00ff9d"/>
        </linearGradient>
      </defs>

      <!-- Needle -->
      <line x1="110" y1="110" x2="185" y2="55" stroke="#00ff9d" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="110" cy="110" r="6" fill="#00ff9d"/>

      <!-- Labels -->
      <text x="14" y="125" fill="#ff4757" font-size="9" font-family="IBM Plex Mono">SELL</text>
      <text x="97" y="20" fill="#ffcc00" font-size="9" font-family="IBM Plex Mono" text-anchor="middle">HOLD</text>
      <text x="193" y="125" fill="#00ff9d" font-size="9" font-family="IBM Plex Mono" text-anchor="end">BUY</text>
    </svg>

    <div style="font-family:'IBM Plex Mono',monospace; font-size:1.4rem; font-weight:700; color:var(--up); margin-top:-10px;">강력 매수</div>
    <div class="signal-badge signal-buy" style="margin-top:8px;">STRONG BUY · 신뢰도 78%</div>
    <div style="font-size:0.7rem; color:var(--muted); margin-top:10px; font-family:'IBM Plex Mono',monospace;">
      37명 애널리스트 합산 · 35명 매수 / 2명 중립
    </div>
  </div>
</div>

