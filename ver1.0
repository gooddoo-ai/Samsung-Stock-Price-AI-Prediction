<!-- Market Factors -->
<div class="card">
  <div class="section-header" style="margin-bottom:10px;">
    <div class="section-title">주가 영향 요인 분석</div>
    <div class="section-line"></div>
  </div>

  <div class="factor-row">
    <div class="factor-name">USD/KRW 환율 (₩1,472)</div>
    <div class="factor-val down">약세</div>
    <div class="factor-impact impact-neg">수출 유리 / 자금이탈</div>
  </div>
  <div class="factor-row">
