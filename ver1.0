  <!-- Disclaimer -->

  <div class="disclaimer">
    <strong>⚠ 투자 주의사항</strong> — 본 대시보드는 실시간 공개 데이터(Investing.com, EIA, TradingView, Stockopedia 등)를 바탕으로 AI가 생성한 참고용 분석 자료입니다.
    주가 예측은 과거 데이터, 거시지표, 애널리스트 컨센서스를 종합한 모델 추정치이며 실제 수익을 보장하지 않습니다.
    투자 결정은 반드시 전문 금융 투자 어드바이저와 상담 후 개인 판단으로 이루어져야 합니다.
    // 데이터 기준일: 2026년 3월 10~11일
  </div>

</div>

<script>
  // Update timestamp
  const now = new Date();
  document.getElementById('updateTime').textContent =
    `갱신: ${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;

  // Price Chart
  const ctx = document.getElementById('priceChart').getContext('2d');

  // Historical + current + predicted data
  const labels = [
    '2025-09','2025-10','2025-11','2025-12',
    '2026-01','2026-02','2026-03 (현재)',
    '2026-03 (예측)','2026-04 (예측)','2026-05 (예측)'
  ];

  const historical = [62000, 58000, 55000, 53000, 63000, 155000, 187900, null, null, null];
  const predicted =  [null, null, null, null, null, null, 187900, 192500, 208000, 220000];
  const targetUpper = [null, null, null, null, null, null, 187900, 205000, 225000, 250000];
  const targetLower = [null, null, null, null, null, null, 187900, 181000, 195000, 195000];

  new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: '실제 주가',
          data: historical,
          borderColor: '#00c8ff',
          backgroundColor: 'rgba(0,200,255,0.08)',
          borderWidth: 2.5,
          pointRadius: 4,
          pointBackgroundColor: '#00c8ff',
          fill: true,
          tension: 0.3,
          spanGaps: false,
        },
        {
          label: 'AI 예측 중앙값',
          data: predicted,
          borderColor: '#00ff9d',
          backgroundColor: 'rgba(0,255,157,0.06)',
          borderWidth: 2.5,
          borderDash: [6, 4],
          pointRadius: 5,
          pointBackgroundColor: '#00ff9d',
          fill: false,
          tension: 0.3,
          spanGaps: false,
        },
        {
          label: '예측 상단 범위',
          data: targetUpper,
          borderColor: 'rgba(255,107,53,0.4)',
          backgroundColor: 'rgba(255,107,53,0.06)',
          borderWidth: 1,
          borderDash: [3, 5],
          pointRadius: 0,
          fill: '+1',
          tension: 0.3,
          spanGaps: false,
        },
        {
          label: '예측 하단 범위',
          data: targetLower,
          borderColor: 'rgba(255,107,53,0.4)',
          backgroundColor: 'rgba(255,107,53,0.06)',
          borderWidth: 1,
          borderDash: [3, 5],
          pointRadius: 0,
          fill: false,
          tension: 0.3,
          spanGaps: false,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          labels: {
            color: '#5b7b9a',
            font: { family: 'IBM Plex Mono', size: 10 },
            boxWidth: 12,
          }
        },
        tooltip: {
          backgroundColor: '#0c1e35',
          borderColor: '#1a3554',
          borderWidth: 1,
          titleColor: '#00c8ff',
          bodyColor: '#e0eaf5',
          titleFont: { family: 'IBM Plex Mono', size: 11 },
          bodyFont: { family: 'IBM Plex Mono', size: 11 },
          callbacks: {
            label: ctx => {
              if (ctx.raw == null) return null;
              return `${ctx.dataset.label}: ₩${ctx.raw.toLocaleString()}`;
            }
          }
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(26,53,84,0.6)' },
          ticks: {
            color: '#5b7b9a',
            font: { family: 'IBM Plex Mono', size: 9 },
            maxRotation: 30,
          }
        },
        y: {
          grid: { color: 'rgba(26,53,84,0.6)' },
          ticks: {
            color: '#5b7b9a',
            font: { family: 'IBM Plex Mono', size: 10 },
            callback: v => '₩' + (v/1000).toFixed(0) + 'K'
          }
        }
      }
    }
  });
</script>

</body>
